generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ItemStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
  DELETED
}

enum FoodType {
  VEG
  NON_VEG
  EGG
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  RECEIVED
  CANCELLED
}

enum StockMovementType {
  PURCHASE
  SALE_CONSUMPTION
  WASTAGE
  ADJUSTMENT
  RETURN
  TRANSFER
}

enum AdjustmentType {
  INCREASE
  DECREASE
}

enum ValuationMethod {
  FIFO
  AVERAGE_COST
}

enum AlertType {
  LOW_STOCK
  OUT_OF_STOCK
  EXPIRING_SOON
  EXPIRED
}

model Category {
  id            String        @id @default(uuid())
  name          String
  description   String?
  imageUrl      String?
  displayOrder  Int           @default(0)
  isEnabled     Boolean       @default(true)
  subCategories SubCategory[]
  menuItems     MenuItem[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("categories")
}

model SubCategory {
  id         String     @id @default(uuid())
  name       String
  categoryId String
  category   Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  menuItems  MenuItem[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@map("sub_categories")
}

model KitchenSection {
  id            String         @id @default(uuid())
  name          String         @unique
  menuItems     MenuItem[]
  kitchenOrders KitchenOrder[]
  createdAt     DateTime       @default(now())

  @@map("kitchen_sections")
}

model MenuItem {
  id        String  @id @default(uuid())
  name      String
  shortName String?
  sku       String  @unique
  barcode   String?

  categoryId    String
  category      Category     @relation(fields: [categoryId], references: [id])
  subCategoryId String?
  subCategory   SubCategory? @relation(fields: [subCategoryId], references: [id])

  foodType         FoodType        @default(VEG)
  kitchenSectionId String?
  kitchenSection   KitchenSection? @relation(fields: [kitchenSectionId], references: [id])

  sellingPrice  Decimal  @db.Decimal(10, 2)
  costPrice     Decimal? @db.Decimal(10, 2)
  gstPercent    Decimal  @default(0) @db.Decimal(5, 2)
  serviceCharge Decimal? @db.Decimal(10, 2)

  isAvailable     Boolean    @default(true)
  isSeasonal      Boolean    @default(false)
  isHiddenFromPOS Boolean    @default(false)
  status          ItemStatus @default(ACTIVE)

  imageUrl           String?
  description        String?
  prepTimeMinutes    Int?
  targetServeMinutes Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  recipeIngredients RecipeIngredient[]
  orderItems        OrderItem[]
  variants          MenuVariant[]
  menuItemAddOns    MenuItemAddOn[]
  comboLinks        ComboItem[]
  priceHistory      PriceHistory[]

  @@map("menu_items")
}

// ─────────────────────────────────────────────
// INVENTORY / STOCK MANAGEMENT
// ─────────────────────────────────────────────

model Unit {
  id           String   @id @default(uuid())
  name         String   @unique // Kg, Gram, Liter, ml, Piece, Packet, Bottle, Box
  abbreviation String?
  createdAt    DateTime @default(now())

  purchaseUnitIngredients    Ingredient[] @relation("PurchaseUnit")
  consumptionUnitIngredients Ingredient[] @relation("ConsumptionUnit")

  @@map("units")
}

model IngredientCategory {
  id          String       @id @default(uuid())
  name        String       @unique // Vegetables, Meat, Dairy, Beverages, Masala, Oil, Packaging, Cleaning
  description String?
  isEnabled   Boolean      @default(true)
  ingredients Ingredient[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("ingredient_categories")
}

model Supplier {
  id                 String   @id @default(uuid())
  name               String
  contactPerson      String?
  phone              String?
  email              String?
  gstNumber          String?
  address            String?
  paymentTerms       String?
  outstandingBalance Decimal  @default(0) @db.Decimal(12, 2)
  isEnabled          Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  purchaseOrders    PurchaseOrder[]
  purchaseEntries   PurchaseEntry[]
  expenses          Expense[]
  recurringExpenses RecurringExpense[]
  assetPurchases    AssetPurchase[]

  @@map("suppliers")
}

model Ingredient {
  id          String  @id @default(uuid())
  name        String
  itemCode    String  @unique
  barcode     String?
  description String?

  categoryId String
  category   IngredientCategory @relation(fields: [categoryId], references: [id])

  purchaseUnitId    String
  purchaseUnit      Unit    @relation("PurchaseUnit", fields: [purchaseUnitId], references: [id])
  consumptionUnitId String
  consumptionUnit   Unit    @relation("ConsumptionUnit", fields: [consumptionUnitId], references: [id])
  conversionRatio   Decimal @default(1) @db.Decimal(12, 4) // 1 purchase unit = X consumption units

  minimumStockLevel Decimal @default(0) @db.Decimal(12, 4)
  isEnabled         Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventoryStock     InventoryStock?
  purchaseOrderItems PurchaseOrderItem[]
  purchaseEntries    PurchaseEntry[]
  stockMovements     StockMovement[]
  stockAdjustments   StockAdjustment[]
  wastageRecords     Wastage[]
  expiryBatches      ExpiryBatch[]
  recipeIngredients  RecipeIngredient[]
  inventoryAlerts    InventoryAlert[]

  @@map("ingredients")
}

model PurchaseOrder {
  id               String              @id @default(uuid())
  poNumber         String              @unique
  supplierId       String
  supplier         Supplier            @relation(fields: [supplierId], references: [id])
  purchaseDate     DateTime            @default(now())
  expectedDelivery DateTime?
  status           PurchaseOrderStatus @default(DRAFT)
  totalAmount      Decimal             @default(0) @db.Decimal(12, 2)
  notes            String?

  items           PurchaseOrderItem[]
  purchaseEntries PurchaseEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  ingredientId    String
  ingredient      Ingredient    @relation(fields: [ingredientId], references: [id])
  quantity        Decimal       @db.Decimal(12, 4)
  unitPrice       Decimal       @db.Decimal(12, 2)
  taxPercent      Decimal       @default(0) @db.Decimal(5, 2)
  totalAmount     Decimal       @db.Decimal(12, 2)

  @@map("purchase_order_items")
}

// Goods receipt — created when stock actually arrives. Increases InventoryStock
// and creates a corresponding StockMovement + optional ExpiryBatch.
model PurchaseEntry {
  id              String         @id @default(uuid())
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  supplierId      String
  supplier        Supplier       @relation(fields: [supplierId], references: [id])
  ingredientId    String
  ingredient      Ingredient     @relation(fields: [ingredientId], references: [id])

  store            String    @default("Main Store")
  invoiceNumber    String?
  batchNumber      String?
  expiryDate       DateTime?
  quantityReceived Decimal   @db.Decimal(12, 4) // in purchase units
  purchasePrice    Decimal   @db.Decimal(12, 2) // per purchase unit
  gstPercent       Decimal   @default(0) @db.Decimal(5, 2)
  discount         Decimal   @default(0) @db.Decimal(12, 2)
  totalAmount      Decimal   @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  @@map("purchase_entries")
}

// Current on-hand snapshot per ingredient — always in consumption units.
// Kept in sync by every StockMovement; avoids summing the whole ledger on every read.
model InventoryStock {
  id             String     @id @default(uuid())
  ingredientId   String     @unique
  ingredient     Ingredient @relation(fields: [ingredientId], references: [id])
  quantityOnHand Decimal    @default(0) @db.Decimal(14, 4) // consumption units
  averageCost    Decimal    @default(0) @db.Decimal(12, 4) // cost per consumption unit
  store          String     @default("Main Store")
  updatedAt      DateTime   @updatedAt

  @@map("inventory_stock")
}

// Full audit ledger — every single stock change, of any kind, lands here.
model StockMovement {
  id            String            @id @default(uuid())
  ingredientId  String
  ingredient    Ingredient        @relation(fields: [ingredientId], references: [id])
  type          StockMovementType
  quantity      Decimal           @db.Decimal(14, 4) // signed: +in / -out, consumption units
  previousStock Decimal           @db.Decimal(14, 4)
  newStock      Decimal           @db.Decimal(14, 4)
  reason        String?
  referenceId   String? // e.g. PurchaseEntry.id, Wastage.id, order id

  // was a plain String before Employee existed — now an optional FK.
  // Scalar column name unchanged, so existing writes of a raw id string still work.
  userId String?
  user   Employee? @relation("StockMovementsByUser", fields: [userId], references: [id])

  store     String   @default("Main Store")
  createdAt DateTime @default(now())

  @@index([ingredientId, createdAt])
  @@map("stock_movements")
}

model StockAdjustment {
  id           String         @id @default(uuid())
  ingredientId String
  ingredient   Ingredient     @relation(fields: [ingredientId], references: [id])
  type         AdjustmentType
  quantity     Decimal        @db.Decimal(14, 4)
  reason       String
  approvedBy   String?
  notes        String?
  createdAt    DateTime       @default(now())

  @@map("stock_adjustments")
}

model Wastage {
  id           String     @id @default(uuid())
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  store        String     @default("Main Store")
  quantity     Decimal    @db.Decimal(14, 4)
  reason       String
  cost         Decimal    @db.Decimal(12, 2)

  // now an optional FK to Employee instead of a loose string
  employeeId String?
  employee   Employee? @relation("WastageByEmployee", fields: [employeeId], references: [id])

  createdAt DateTime @default(now())

  @@map("wastage")
}

model ExpiryBatch {
  id                String     @id @default(uuid())
  ingredientId      String
  ingredient        Ingredient @relation(fields: [ingredientId], references: [id])
  batchNumber       String
  manufacturingDate DateTime?
  expiryDate        DateTime
  quantityRemaining Decimal    @db.Decimal(14, 4)
  createdAt         DateTime   @default(now())

  @@index([expiryDate])
  @@map("expiry_batches")
}

// Links a MenuItem to the ingredients (and quantities) consumed per single unit sold.
model RecipeIngredient {
  id           String     @id @default(uuid())
  menuItemId   String
  menuItem     MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  quantity     Decimal    @db.Decimal(12, 4) // in ingredient's consumption unit
  createdAt    DateTime   @default(now())

  @@unique([menuItemId, ingredientId])
  @@map("recipe_ingredients")
}

// Pre-computed alert rows so the dashboard doesn't have to scan everything live.
model InventoryAlert {
  id           String     @id @default(uuid())
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  type         AlertType
  message      String
  isResolved   Boolean    @default(false)
  createdAt    DateTime   @default(now())

  @@map("inventory_alerts")
}

enum ExpenseStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  PAID
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  OVERDUE
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  BANK_TRANSFER
  CHEQUE
  OTHER
}

enum RecurringFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum ApprovalAction {
  APPROVED
  REJECTED
}

enum ApprovalLevel {
  MANAGER
  FINANCE
}

model ExpenseCategory {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  isDefault   Boolean @default(false) // true for seeded defaults (Rent, Electricity, etc.)
  isEnabled   Boolean @default(true)
  icon        String? @default("FiTag")
  color       String? @default("blue")

  expenses          Expense[]
  recurringExpenses RecurringExpense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("expense_categories")
}

model Store {
  id       String  @id @default(uuid())
  name     String  @unique
  address  String?
  phone    String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("stores")
}

// Core expense record. Utility bills and petty cash entries also live here
// (via isPettyCash / pettyCashSessionId) so P&L can sum one table for totals,
// while UtilityBill/PettyCashSession hold the feature-specific metadata.
model Expense {
  id            String @id @default(uuid())
  expenseNumber String @unique // auto-generated, e.g. EXP-000123

  categoryId String
  category   ExpenseCategory @relation(fields: [categoryId], references: [id])

  title       String
  description String?
  expenseDate DateTime @default(now())

  amount    Decimal @db.Decimal(12, 2)
  gstAmount Decimal @default(0) @db.Decimal(12, 2)
  discount  Decimal @default(0) @db.Decimal(12, 2)
  totalPaid Decimal @db.Decimal(12, 2)

  supplierId    String?
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  invoiceNumber String?

  paymentMethod        PaymentMethod?
  paymentStatus        PaymentStatus  @default(UNPAID)
  paymentDate          DateTime?
  transactionReference String?

  status ExpenseStatus @default(DRAFT)
  store  String        @default("Main Store")

  isPettyCash        Boolean           @default(false)
  pettyCashSessionId String?
  pettyCashSession   PettyCashSession? @relation(fields: [pettyCashSessionId], references: [id])

  recurringExpenseId String?
  recurringExpense   RecurringExpense? @relation(fields: [recurringExpenseId], references: [id])

  // now an optional FK to Employee instead of a loose string
  createdBy         String?
  createdByEmployee Employee? @relation("ExpensesCreatedBy", fields: [createdBy], references: [id])

  attachments ExpenseAttachment[]
  approvals   ExpenseApproval[]
  auditLogs   ExpenseAuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expenseDate])
  @@index([status])
  @@map("expenses")
}

model ExpenseAttachment {
  id         String   @id @default(uuid())
  expenseId  String
  expense    Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  fileKey    String // R2 object key
  fileUrl    String
  fileType   String // pdf / jpg / png
  uploadedAt DateTime @default(now())

  @@map("expense_attachments")
}

// Template for recurring expenses (Rent, Internet, Software Subscription...).
// A scheduler reads isActive + nextDueDate and spins off real Expense rows.
model RecurringExpense {
  id         String          @id @default(uuid())
  categoryId String
  category   ExpenseCategory @relation(fields: [categoryId], references: [id])

  title  String
  amount Decimal @db.Decimal(12, 2)

  frequency          RecurringFrequency
  nextDueDate        DateTime
  reminderDaysBefore Int                @default(3)
  isActive           Boolean            @default(true)

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])
  store      String    @default("Main Store")

  expenses Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("recurring_expenses")
}

// Audit trail for the approval workflow (Manager -> Finance).
model ExpenseApproval {
  id        String         @id @default(uuid())
  expenseId String
  expense   Expense        @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  action    ApprovalAction
  level     ApprovalLevel

  // now an optional FK to Employee instead of a loose string
  approverId String?
  approver   Employee? @relation("ExpenseApprovalsByApprover", fields: [approverId], references: [id])

  comment   String?
  createdAt DateTime @default(now())

  @@map("expense_approvals")
}

// HR-side monthly payroll computation for an employee (basic + allowances -
// deductions = net). When processed/paid, a corresponding SalaryExpense row
// is created below so it lands in the accounting/P&L ledger too.
model PayrollRecord {
  id         String   @id @default(uuid())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String

  month       String // "2026-07"
  basicSalary Decimal      @db.Decimal(12, 2)
  allowances  Decimal      @default(0) @db.Decimal(12, 2)
  bonus       Decimal      @default(0) @db.Decimal(12, 2)
  overtimePay Decimal      @default(0) @db.Decimal(12, 2)
  deductions  Decimal      @default(0) @db.Decimal(12, 2)
  netSalary   Decimal      @db.Decimal(12, 2)
  status      SalaryStatus @default(PENDING)

  // filled in once this payroll run has been pushed into the Expense ledger
  salaryExpenseId String?        @unique
  salaryExpense   SalaryExpense? @relation(fields: [salaryExpenseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, month])
  @@map("payroll_records")
}

// Accounting-side ledger entry (unchanged shape, now linked to a real Employee
// where one exists; employeeName kept for cases without a system account).
model SalaryExpense {
  id           String    @id @default(uuid())
  employeeName String
  employeeId   String?
  employee     Employee? @relation("SalaryExpensesByEmployee", fields: [employeeId], references: [id])
  salaryMonth  DateTime // stored as the 1st of the month

  baseSalary Decimal @db.Decimal(12, 2)
  bonus      Decimal @default(0) @db.Decimal(12, 2)
  incentives Decimal @default(0) @db.Decimal(12, 2)
  overtime   Decimal @default(0) @db.Decimal(12, 2)
  deductions Decimal @default(0) @db.Decimal(12, 2)
  netSalary  Decimal @db.Decimal(12, 2)

  paymentStatus PaymentStatus @default(UNPAID)
  paymentDate   DateTime?
  store         String        @default("Main Store")

  payrollRecord PayrollRecord?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([salaryMonth])
  @@map("salary_expenses")
}

model UtilityBill {
  id                 String        @id @default(uuid())
  utilityType        String // Electricity, Water, Gas, Internet
  billNumber         String?
  billingPeriodStart DateTime
  billingPeriodEnd   DateTime
  dueDate            DateTime
  paymentDate        DateTime?
  amount             Decimal       @db.Decimal(12, 2)
  paymentStatus      PaymentStatus @default(UNPAID)
  store              String        @default("Main Store")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dueDate])
  @@map("utility_bills")
}

// A session/ledger period (e.g. one per day or week per store).
// Individual petty cash spends are Expense rows with isPettyCash=true,
// linked back here via pettyCashSessionId.
model PettyCashSession {
  id             String    @id @default(uuid())
  store          String    @default("Main Store")
  periodStart    DateTime
  periodEnd      DateTime?
  openingBalance Decimal   @db.Decimal(12, 2)
  closingBalance Decimal?  @db.Decimal(12, 2)
  isClosed       Boolean   @default(false)

  expenses Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("petty_cash_sessions")
}

model AssetPurchase {
  id             String    @id @default(uuid())
  assetName      String
  assetCategory  String? // Furniture, Kitchen Equipment, Computers, Printers, POS Devices
  purchaseDate   DateTime  @default(now())
  cost           Decimal   @db.Decimal(12, 2)
  warrantyExpiry DateTime?

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])
  store      String    @default("Main Store")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("asset_purchases")
}

model ExpenseAuditLog {
  id        String  @id @default(uuid())
  expenseId String
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  action    String // CREATE, UPDATE, DELETE, APPROVE, REJECT

  // now an optional FK to Employee instead of a loose string
  changedBy         String?
  changedByEmployee Employee? @relation("ExpenseAuditLogsByEmployee", fields: [changedBy], references: [id])

  oldValue  Json?
  newValue  Json?
  createdAt DateTime @default(now())

  @@map("expense_audit_logs")
}

// ─────────────────────────────────────────────
// EMPLOYEE & STAFF MANAGEMENT
// ─────────────────────────────────────────────

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  RESIGNED
  TERMINATED
}

enum RoleName {
  OWNER
  ADMIN
  MANAGER
  CASHIER
  CHEF
  KITCHEN
  WAITER
  STORE_KEEPER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
  HOLIDAY
}

enum AttendanceEventType {
  CLOCK_IN
  CLOCK_OUT
  BREAK_START
  BREAK_END
}

enum LeaveType {
  CASUAL
  SICK
  PAID
  EMERGENCY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SalaryStatus {
  PAID
  PENDING
}

model Employee {
  id               String    @id @default(uuid())
  employeeCode     String    @unique // auto-generated, e.g. EMP-0001
  fullName         String
  photoUrl         String?
  gender           String?
  dob              DateTime?
  mobile           String?
  email            String?   @unique
  emergencyContact String?

  department     String // free text — Kitchen, Service, Inventory...
  designation    String // free text — Chef, Waiter, Cashier...
  joiningDate    DateTime
  employmentType String? // free text — full-time / part-time / contract
  status         EmployeeStatus @default(ACTIVE)
  store          String         @default("Main Store") // matches store convention used across inventory/expenses

  address            EmployeeAddress?
  userAccount        UserAccount?
  attendance         Attendance[]
  attendanceLogs     AttendanceLog[]
  shiftAssignments   ShiftAssignment[]
  leaveRequests      LeaveRequest[]
  approvedLeaves     LeaveRequest[]      @relation("LeaveApprovedBy")
  payrollRecords     PayrollRecord[]
  incentives         Incentive[]
  approvedIncentives Incentive[]         @relation("IncentiveApprovedBy")
  performanceRecords PerformanceRecord[]
  activityLogs       ActivityLog[]

  // reverse relations into existing modules
  stockMovements   StockMovement[]   @relation("StockMovementsByUser")
  wastageRecords   Wastage[]         @relation("WastageByEmployee")
  expensesCreated  Expense[]         @relation("ExpensesCreatedBy")
  expenseApprovals ExpenseApproval[] @relation("ExpenseApprovalsByApprover")
  salaryExpenses   SalaryExpense[]   @relation("SalaryExpensesByEmployee")
  expenseAuditLogs ExpenseAuditLog[] @relation("ExpenseAuditLogsByEmployee")

  ordersAsWaiter    Order[]         @relation("OrdersByWaiter")
  assignedTables    RestaurantTable[] @relation("TablesByWaiter")
  discountsApproved OrderDiscount[] @relation("DiscountsApprovedBy")

  kitchenOrdersAsChef  KitchenOrder[]          @relation("KOTsByChef")
  kitchenStatusChanges KitchenOrderStatusLog[] @relation("KOTStatusChangedBy")
  kitchenNotes         KitchenNote[]           @relation("KitchenNotesByChef")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([department])
  @@index([designation])
  @@index([status])
  @@map("employees")
}

model EmployeeAddress {
  id         String   @id @default(uuid())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String   @unique

  houseNo String?
  street  String?
  city    String?
  state   String?
  pincode String?

  @@map("employee_addresses")
}

// Login schema only — no auth middleware wired yet.
model UserAccount {
  id         String   @id @default(uuid())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String   @unique

  username            String    @unique
  email               String?   @unique
  passwordHash        String
  pin                 String? // optional, for POS quick login
  role                RoleName
  isActive            Boolean   @default(true)
  lastLoginAt         DateTime?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  passwordResetTokens PasswordResetToken[]
  refreshTokens       RefreshToken[]       @relation("RefreshTokensByUser")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@map("user_accounts")
}

// Short-lived token issued for the "forgot password" flow. Only the hash is
// stored — the raw token is emailed to the user and never persisted.
model PasswordResetToken {
  id            String      @id @default(uuid())
  userAccountId String
  userAccount   UserAccount @relation(fields: [userAccountId], references: [id], onDelete: Cascade)
  tokenHash     String      @unique
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime    @default(now())

  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// Long-lived refresh tokens (httpOnly cookie on the client). Stored hashed so
// a DB leak doesn't hand out usable tokens; revoked on logout / password change.
model RefreshToken {
  id            String      @id @default(uuid())
  userAccountId String
  userAccount   UserAccount @relation("RefreshTokensByUser", fields: [userAccountId], references: [id], onDelete: Cascade)
  tokenHash     String      @unique
  expiresAt     DateTime
  revokedAt     DateTime?
  createdAt     DateTime    @default(now())

  @@index([userAccountId])
  @@map("refresh_tokens")
}

// Daily rollup — one row per employee per day.
model Attendance {
  id         String   @id @default(uuid())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String

  date          DateTime         @db.Date
  clockIn       DateTime?
  clockOut      DateTime?
  workingHours  Decimal?         @db.Decimal(5, 2)
  overtimeHours Decimal?         @db.Decimal(5, 2)
  status        AttendanceStatus @default(PRESENT)
  store         String           @default("Main Store")

  @@unique([employeeId, date])
  @@index([date])
  @@map("attendance")
}

// Raw event log — clock-in/out and break events, multiple per day.
model AttendanceLog {
  id         String   @id @default(uuid())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String

  eventType AttendanceEventType
  timestamp DateTime            @default(now())
  ipAddress String?
  device    String?

  @@index([employeeId, timestamp])
  @@map("attendance_logs")
}

model Shift {
  id        String @id @default(uuid())
  name      String // Morning / Afternoon / Night / Custom
  startTime String // "09:00"
  endTime   String // "17:00"
  store     String @default("Main Store")

  assignments ShiftAssignment[]

  createdAt DateTime @default(now())

  @@map("shifts")
}

model ShiftAssignment {
  id         String   @id @default(uuid())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String
  shift      Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  shiftId    String

  date DateTime @db.Date

  @@unique([employeeId, date])
  @@index([shiftId, date])
  @@map("shift_assignments")
}

model LeaveRequest {
  id         String   @id @default(uuid())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String

  type     LeaveType
  fromDate DateTime
  toDate   DateTime
  reason   String?
  status   LeaveStatus @default(PENDING)

  approvedById String?
  approvedBy   Employee? @relation("LeaveApprovedBy", fields: [approvedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId, status])
  @@map("leave_requests")
}

model Incentive {
  id         String   @id @default(uuid())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String

  type   String // free text — Sales Target Bonus, Attendance Bonus, Festival Bonus
  amount Decimal @db.Decimal(12, 2)
  reason String?

  approvedById String?
  approvedBy   Employee? @relation("IncentiveApprovedBy", fields: [approvedById], references: [id])

  createdAt DateTime @default(now())

  @@map("incentives")
}

model PerformanceRecord {
  id         String   @id @default(uuid())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String

  period         String // "2026-07"
  ordersServed   Int?     @default(0)
  salesGenerated Decimal? @default(0) @db.Decimal(12, 2)
  customerRating Decimal? @db.Decimal(3, 2)
  lateArrivals   Int?     @default(0)

  @@unique([employeeId, period])
  @@map("performance_records")
}

model ActivityLog {
  id         String   @id @default(uuid())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String

  action    String // e.g. "Login", "Created Order", "Updated Inventory"
  ipAddress String?
  device    String?
  createdAt DateTime @default(now())

  @@index([employeeId, createdAt])
  @@map("employee_activity_logs")
}

// ─────────────────────────────────────────────
// POS / ORDERS
// ─────────────────────────────────────────────

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum OrderStatus {
  NEW
  ACCEPTED
  PREPARING
  READY
  SERVED
  OUT_FOR_DELIVERY
  COMPLETED
  CANCELLED
  REFUNDED
  ON_HOLD
}

enum TableStatus {
  FREE
  OCCUPIED
  RESERVED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  COUPON
  MEMBERSHIP
  MANUAL
}

enum KotStatus {
  NEW
  ACCEPTED
  PREPARING
  READY
  SERVED
  COMPLETED
  CANCELLED
  RECALLED
}

enum KotPriority {
  NORMAL
  VIP
  ONLINE_DELIVERY
  EXPRESS
  SENIOR_CITIZEN
  SPECIAL_REQUEST
}

enum SplitType {
  EQUAL
  ITEM_WISE
  CUSTOM
}

// A floor/section of the restaurant, e.g. "Ground Floor", "Rooftop".
// Tables are grouped under a floor for the Tables Management page (floor
// tabs + per-floor table grid).
model Floor {
  id    String  @id @default(uuid())
  name  String
  store String? @default("Main Store")

  tables RestaurantTable[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("floors")
}

model RestaurantTable {
  id       String      @id @default(uuid())
  name     String // e.g. "T-12"
  capacity Int?
  section  String? // legacy free-text grouping, kept for back-compat with existing filters
  status   TableStatus @default(FREE)
  store    String?     @default("Main Store")

  floorId String?
  floor   Floor?  @relation(fields: [floorId], references: [id])

  // Waiter assignment — a table is assigned to at most one waiter at a time.
  // Owner/Manager assigns via /pos/tables/assign* endpoints; the waiter then
  // only sees orders/payments for tables where waiterId === their own id.
  waiterId   String?
  waiter     Employee? @relation("TablesByWaiter", fields: [waiterId], references: [id])
  assignedAt DateTime?

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([floorId])
  @@index([waiterId])
  @@map("restaurant_tables")
}

model Customer {
  id            String  @id @default(uuid())
  name          String
  mobile        String  @unique
  email         String?
  address       String?
  landmark      String?
  loyaltyPoints Int     @default(0)

  orders              Order[]
  loyaltyTransactions LoyaltyTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([mobile])
  @@map("customers")
}

model DeliveryPartner {
  id       String  @id @default(uuid())
  name     String
  phone    String?
  isActive Boolean @default(true)

  orders Order[]

  createdAt DateTime @default(now())

  @@map("delivery_partners")
}

model Order {
  id          String      @id @default(uuid())
  orderNumber String      @unique // e.g. ORD-000123
  orderType   OrderType
  status      OrderStatus @default(NEW)
  holdNumber  String?     @unique

  tableId String?
  table   RestaurantTable? @relation(fields: [tableId], references: [id])

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  waiterId String?
  waiter   Employee? @relation("OrdersByWaiter", fields: [waiterId], references: [id])

  numberOfGuests Int?

  // delivery-specific
  deliveryPartnerId     String?
  deliveryPartner       DeliveryPartner? @relation(fields: [deliveryPartnerId], references: [id])
  deliveryCharge        Decimal?         @db.Decimal(10, 2)
  deliveryStatus        String?
  estimatedDeliveryTime DateTime?
  deliveryAddress       String?

  // takeaway-specific
  pickupTime      DateTime?
  packagingCharge Decimal?  @db.Decimal(10, 2)

  // money
  subtotal            Decimal @db.Decimal(12, 2)
  discountAmount      Decimal @default(0) @db.Decimal(12, 2)
  gstAmount           Decimal @default(0) @db.Decimal(12, 2)
  serviceChargeAmount Decimal @default(0) @db.Decimal(12, 2)
  grandTotal          Decimal @db.Decimal(12, 2)

  notes String?
  store String  @default("Main Store")

  items               OrderItem[]
  payments            Payment[]
  kitchenOrders       KitchenOrder[]
  invoice             Invoice?
  billSplits          BillSplit[]
  discountsApplied    OrderDiscount[]
  loyaltyTransactions LoyaltyTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([orderType])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  quantity   Int
  unitPrice  Decimal @db.Decimal(10, 2) // snapshot at order time
  totalPrice Decimal @db.Decimal(12, 2)
  notes      String? // customization, printed on KOT

  addOns            OrderItemAddOn[]
  kitchenOrderItems KitchenOrderItem[]

  createdAt DateTime @default(now())

  @@map("order_items")
}

model AddOn {
  id        String  @id @default(uuid())
  name      String
  price     Decimal @db.Decimal(10, 2)
  isEnabled Boolean @default(true)

  orderItemAddOns OrderItemAddOn[]
  menuItems       MenuItemAddOn[]

  createdAt DateTime @default(now())

  @@map("add_ons")
}

model OrderItemAddOn {
  id          String    @id @default(uuid())
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  addOnId     String
  addOn       AddOn     @relation(fields: [addOnId], references: [id])

  quantity   Int     @default(1)
  unitPrice  Decimal @db.Decimal(10, 2)
  totalPrice Decimal @db.Decimal(12, 2)

  @@map("order_item_add_ons")
}

model Discount {
  id             String       @id @default(uuid())
  code           String?      @unique
  type           DiscountType
  value          Decimal      @db.Decimal(10, 2) // percent or fixed amount
  isActive       Boolean      @default(true)
  validFrom      DateTime?
  validTo        DateTime?
  usageLimit     Int?
  minOrderAmount Decimal?     @db.Decimal(12, 2)
  store          String       @default("Main Store")

  orderDiscounts OrderDiscount[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("discounts")
}

model OrderDiscount {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  discountId String?
  discount   Discount? @relation(fields: [discountId], references: [id])

  type           DiscountType
  amountDeducted Decimal      @db.Decimal(12, 2)
  reason         String?

  approvedById String?
  approvedBy   Employee? @relation("DiscountsApprovedBy", fields: [approvedById], references: [id])

  createdAt DateTime @default(now())

  @@map("order_discounts")
}

model Payment {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  method               PaymentMethod
  amount               Decimal       @db.Decimal(12, 2)
  status               PaymentStatus @default(UNPAID)
  transactionReference String?
  paidAt               DateTime?

  billSplitId String?
  billSplit   BillSplit? @relation(fields: [billSplitId], references: [id])

  createdAt DateTime @default(now())

  @@map("payments")
}

model BillSplit {
  id        String    @id @default(uuid())
  orderId   String
  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  splitType SplitType
  label     String // e.g. "Customer A"
  amount    Decimal   @db.Decimal(12, 2)

  payments Payment[]

  createdAt DateTime @default(now())

  @@map("bill_splits")
}

model KitchenOrder {
  id        String      @id @default(uuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  kotNumber String      @unique
  status    KotStatus   @default(NEW)
  priority  KotPriority @default(NORMAL)

  kitchenSectionId String
  kitchenSection   KitchenSection @relation(fields: [kitchenSectionId], references: [id])

  chefId String?
  chef   Employee? @relation("KOTsByChef", fields: [chefId], references: [id])

  // target time is a snapshot (sum/max of item prep times) so it doesn't
  // shift if MenuItem.prepTimeMinutes changes later
  targetPrepMinutes Int?
  isDelayed         Boolean @default(false)
  recallCount       Int     @default(0)

  // key lifecycle timestamps — cheap to read for live timers/dashboard;
  // full history of every transition lives in KitchenOrderStatusLog
  acceptedAt  DateTime?
  readyAt     DateTime?
  servedAt    DateTime?
  completedAt DateTime?
  recalledAt  DateTime?

  items      KitchenOrderItem[]
  statusLogs KitchenOrderStatusLog[]
  notes      KitchenNote[]

  printedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status])
  @@index([kitchenSectionId, status])
  @@index([isDelayed])
  @@map("kitchen_orders")
}

model KitchenOrderItem {
  id             String       @id @default(uuid())
  kitchenOrderId String
  kitchenOrder   KitchenOrder @relation(fields: [kitchenOrderId], references: [id], onDelete: Cascade)
  orderItemId    String
  orderItem      OrderItem    @relation(fields: [orderItemId], references: [id])
  quantity       Int

  @@map("kitchen_order_items")
}

model KitchenOrderStatusLog {
  id             String       @id @default(uuid())
  kitchenOrderId String
  kitchenOrder   KitchenOrder @relation(fields: [kitchenOrderId], references: [id], onDelete: Cascade)

  fromStatus KotStatus?
  toStatus   KotStatus

  changedById String?
  changedBy   Employee? @relation("KOTStatusChangedBy", fields: [changedById], references: [id])

  reason String? // e.g. "Recalled by waiter", "Modified item"

  createdAt DateTime @default(now())

  @@index([kitchenOrderId, createdAt])
  @@map("kitchen_order_status_logs")
}

model KitchenNote {
  id             String       @id @default(uuid())
  kitchenOrderId String
  kitchenOrder   KitchenOrder @relation(fields: [kitchenOrderId], references: [id], onDelete: Cascade)

  chefId String?
  chef   Employee? @relation("KitchenNotesByChef", fields: [chefId], references: [id])

  note      String
  createdAt DateTime @default(now())

  @@map("kitchen_notes")
}

model Invoice {
  id            String  @id @default(uuid())
  orderId       String  @unique
  order         Order   @relation(fields: [orderId], references: [id])
  invoiceNumber String  @unique
  gstNumber     String?
  sentVia       String? // print / email / whatsapp — comma-separated or JSON if multiple
  pdfUrl        String?

  createdAt DateTime @default(now())

  @@map("invoices")
}

model LoyaltyTransaction {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  orderId    String?
  order      Order?   @relation(fields: [orderId], references: [id])

  points Int // signed: + earn / - redeem
  reason String?

  createdAt DateTime @default(now())

  @@map("loyalty_transactions")
}

// ─────────────────────────────────────────────
// MENU MANAGEMENT — ADDITIVE MODELS
// Paste this block at the end of your existing schema.prisma.
// These attach onto the existing MenuItem/AddOn/Category models
// without altering anything already defined above.
// ─────────────────────────────────────────────

// Small / Medium / Large style variants for a single menu item
model MenuVariant {
  id              String   @id @default(uuid())
  menuItemId      String
  menuItem        MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  name            String // e.g. "Small", "Medium", "Large"
  price           Decimal  @db.Decimal(10, 2)
  prepTimeMinutes Int?
  calories        Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("menu_variants")
}

// Optional: restrict which add-ons show up for a given menu item in the
// admin/catalog UI. Not required by the POS order flow (AddOn/OrderItemAddOn
// already work independently of this) — purely a curation layer.
// If you never populate this table, every add-on stays available everywhere.
model MenuItemAddOn {
  id         String   @id @default(uuid())
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  addOnId    String
  addOn      AddOn    @relation(fields: [addOnId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([menuItemId, addOnId])
  @@map("menu_item_addons")
}

// Combo meals — bundle several menu items at a fixed price
model ComboMeal {
  id          String      @id @default(uuid())
  name        String
  price       Decimal     @db.Decimal(10, 2)
  description String?
  imageUrl    String?
  isEnabled   Boolean     @default(true)
  items       ComboItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("combo_meals")
}

model ComboItem {
  id          String    @id @default(uuid())
  comboMealId String
  comboMeal   ComboMeal @relation(fields: [comboMealId], references: [id], onDelete: Cascade)
  menuItemId  String
  menuItem    MenuItem  @relation(fields: [menuItemId], references: [id])
  quantity    Int       @default(1)

  @@map("combo_items")
}

// Audit trail — logged automatically whenever MenuItem.sellingPrice changes
model PriceHistory {
  id         String   @id @default(uuid())
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  oldPrice   Decimal  @db.Decimal(10, 2)
  newPrice   Decimal  @db.Decimal(10, 2)
  changedBy  String? // userAccountId (req.user.id) of whoever made the change
  changedAt  DateTime @default(now())

  @@map("price_history")
}
